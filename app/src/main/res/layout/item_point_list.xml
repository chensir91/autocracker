<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#10000000"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- 序号 -->
    <TextView
        android:id="@+id/tvPointOrder"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#757575"
        android:textSize="11sp" />

    <!-- 类型+坐标 -->
    <TextView
        android:id="@+id/tvPointInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#212121"
        android:textSize="11sp" />

    <!-- 显示按钮 -->
    <ImageButton
        android:id="@+id/btnShowPoint"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@null"
        android:contentDescription="显示"
        android:src="@android:drawable/ic_menu_view"
        android:tint="#757575" />

    <!-- 调整按钮 -->
    <ImageButton
        android:id="@+id/btnEditPoint"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@null"
        android:contentDescription="调整"
        android:src="@android:drawable/ic_menu_edit"
        android:tint="#757575"
        android:visibility="gone" />

    <!-- 删除按钮 -->
    <ImageButton
        android:id="@+id/btnDeletePoint"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@null"
        android:contentDescription="删除"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="#F44336"
        android:visibility="gone" />

    <!-- 等待时长调整控件（仅WAIT类型被选中时显示） -->
    <LinearLayout
        android:id="@+id/waitDurationControls"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnDecreaseWait"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="#20000000"
            android:contentDescription="减少"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#757575" />

        <TextView
            android:id="@+id/tvWaitDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:minWidth="40dp"
            android:gravity="center"
            android:textColor="#212121"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/btnIncreaseWait"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="#20000000"
            android:contentDescription="增加"
            android:src="@android:drawable/ic_media_next"
            android:tint="#757575" />
    </LinearLayout>

</LinearLayout>
