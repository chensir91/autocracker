<?xml version="1.0" encoding="utf-8"?>
<com.autoclicker.arknights.ui.DraggableFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/draggableContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/floatingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_floating_window"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="6dp">

        <!-- 录制按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_floating_button"
                android:contentDescription="录制"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/status_recording" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="录制"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 开始/暂停按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnStartPause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_floating_button"
                android:contentDescription="开始"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/primary" />

            <TextView
                android:id="@+id/tvStartPauseLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 停止按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnStop"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_floating_button"
                android:contentDescription="停止"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="停止"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 撤销按钮 -->
        <LinearLayout
            android:id="@+id/layoutUndo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnUndo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_floating_button"
                android:contentDescription="撤销"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="撤销"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 设置按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_floating_button"
                android:contentDescription="设置"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_preferences"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设置"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 定时按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnScheduled"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_floating_button"
                android:contentDescription="定时"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="定时"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 最小化按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnMinimize"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_floating_button"
                android:contentDescription="最小化"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最小化"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- 进度显示（叠加在按钮上） -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="2dp"
        android:background="#80000000"
        android:paddingStart="4dp"
        android:paddingTop="2dp"
        android:paddingEnd="4dp"
        android:paddingBottom="2dp"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:visibility="gone" />

    <!-- 倒计时显示 -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:background="#80000000"
        android:paddingStart="4dp"
        android:paddingTop="2dp"
        android:paddingEnd="4dp"
        android:paddingBottom="2dp"
        android:textColor="@color/status_running"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />

</com.autoclicker.arknights.ui.DraggableFrameLayout>
