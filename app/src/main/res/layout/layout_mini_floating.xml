<?xml version="1.0" encoding="utf-8"?>
<com.autoclicker.arknights.ui.DraggableFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/draggableContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- 小圆点背景 -->
    <LinearLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_mini_floating"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp"
        android:clickable="false"
        android:focusable="false">

        <!-- 图标 -->
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_edit"
            android:clickable="false"
            android:focusable="false"
            app:tint="@color/text_on_primary" />

    </LinearLayout>

</com.autoclicker.arknights.ui.DraggableFrameLayout>
